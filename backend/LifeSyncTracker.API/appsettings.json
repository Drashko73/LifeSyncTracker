{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "ConnectionStrings": {
        "SqliteConnection": "Data Source=lifesync.db",
        "PostgresConnection": "Host=localhost;Database=lifesynctracker;Username=postgres;Password=postgres"
    },
    "Jwt": {
        "Key": "YourSuperSecretKeyThatIsAtLeast32CharactersLong!",
        "Issuer": "LifeSyncTracker",
        "Audience": "LifeSyncTrackerUsers",
        "AccessTokenExpiryMinutes": 15
    },
    "RefreshToken": {
        "ExpiryDays": 7
    },
    "Email": {
        "Host": "smtp.example.com",
        "Port": 587,
        "EnableSsl": true,
        "Username": "smtp-username",
        "Password": "smtp-password",
        "FromEmail": "noreply@example.com",
        "FromName": "LifeSync Tracker"
    },
    "EmailVerification": {
        "CodeLength": 6,
        "ExpirationMinutes": 15
    }
}
